<mujoco model="so_arm100 pick and place">
  <include file="so_arm100.xml"/>

  <statistic center="0 -0.3 0.1" extent="0.5"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="45" elevation="-20" offwidth="960" offheight="720"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <material name="table_yellow" rgba="0.95 0.85 0.3 1"/>
    <material name="zone_gray" rgba="0.55 0.55 0.55 1"/>
    <material name="cube_red" rgba="0.95 0.15 0.15 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Yellow table (robosuite-style: friction for grip) -->
    <body name="table" pos="0 -0.40 0.05">
      <geom type="box" size="0.15 0.20 0.005" material="table_yellow"
        friction="1 0.005 0.0001"/>
    </body>

    <!-- Source zone (left gray area) -->
    <body name="zone_source" pos="0.08 -0.32 0.056">
      <geom type="box" size="0.05 0.05 0.001" material="zone_gray"/>
    </body>

    <!-- Target zone (right gray area) -->
    <body name="zone_target" pos="-0.08 -0.48 0.056">
      <geom type="box" size="0.05 0.05 0.001" material="zone_gray"/>
    </body>

    <!-- Red cube: drops from above onto source zone -->
    <body name="cube" pos="0.08 -0.32 0.25">
      <freejoint/>
      <geom type="box" size="0.012 0.012 0.012" material="cube_red" mass="0.02"
        solref="0.02 1" solimp="0.9 0.95 0.001"/>
    </body>
  </worldbody>
</mujoco>
